# Use Binance Futures Testnet credentials only. Never use production keys here.
BINANCE_API_KEY=your_testnet_api_key_here
BINANCE_API_SECRET=your_testnet_api_secret_here

# Assignment-required default:
BINANCE_FUTURES_BASE_URL=https://testnet.binancefuture.com

# If your Binance Futures Testnet account has been migrated and the assignment allows it,
# you can try Binance's current USDS-M testnet endpoint instead:
# BINANCE_FUTURES_BASE_URL=https://demo-fapi.binance.com
